NODE_ENV=development
PORT=4000
SQLITE_PATH=../../data/sqlite/plex-exporter.sqlite

# Optional API bearer token for protected routes
API_TOKEN=

# Optional admin basic auth (both required together)
ADMIN_USERNAME=
ADMIN_PASSWORD=

# Optional TMDB integration
TMDB_ACCESS_TOKEN=

# Optional Tautulli integration (both required together)
TAUTULLI_URL=
TAUTULLI_API_KEY=

# Optional Resend integration (both required together)
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Optional Hero policy override path
HERO_POLICY_PATH=
